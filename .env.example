# Supabase — reviews + price-request backend (see src/lib/supabase.ts).
# Copy this file to `.env` and fill in your project values.
# Until both are set, the testimonials section falls back to seed data and the
# "Add a review" / "Ask the price" forms run in offline/demo mode.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Telegram price-request notifications (supabase/functions/notify-quote) are
# configured as Supabase Edge Function secrets, NOT Vite env vars — they run
# server-side and must never reach the browser. Set them with:
#   supabase secrets set TELEGRAM_BOT_TOKEN=... TELEGRAM_CHAT_ID=...
# (TELEGRAM_BOT_TOKEN from @BotFather; TELEGRAM_CHAT_ID = target chat/group id.)
